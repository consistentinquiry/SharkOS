#!/usr/bin/env bash
# ┌──────────────────────────────────────────────────────────────────┐
# │  SharkOS first-boot desktop install                              │
# │  Runs once (as root, via sharkos-firstboot.service) on the newly │
# │  installed system, then auto-reboots into SharkOS.               │
# │                                                                    │
# │  install.sh refuses root and builds AUR packages, so we drop to   │
# │  the primary user to run it. That user has no way to type a sudo  │
# │  password unattended, so we open a temporary passwordless-sudo    │
# │  window bracketed entirely around the run and tear it down after. │
# └──────────────────────────────────────────────────────────────────┘
set -uo pipefail

DONE_MARKER="/var/lib/sharkos/.firstboot-done"
SUDO_DROPIN="/etc/sudoers.d/99-sharkos-firstboot"
SWAPFILE="/var/lib/sharkos/install-swap"
SETUP_URL="https://raw.githubusercontent.com/consistentinquiry/SharkOS/main/install.sh"
made_swap=0

mkdir -p "$(dirname "$DONE_MARKER")"
[ -e "$DONE_MARKER" ] && exit 0

# Primary user is archinstall's first account (UID 1000). Using getent avoids a
# dependency on awk/gawk, which is not guaranteed in a minimal base install.
USERNAME="$(getent passwd 1000 | cut -d: -f1)"
if [ -z "${USERNAME:-}" ]; then
  echo "sharkos-firstboot: no user at UID 1000; aborting." >&2
  exit 1
fi

echo
echo "  ┌─ SharkOS first-boot setup ──────────────────────────────────┐"
echo "  │  Installing the SharkOS desktop for user '$USERNAME'."
echo "  │  This downloads packages and may take a while. Leave it be.  │"
echo "  └──────────────────────────────────────────────────────────────┘"
echo

# Belt-and-suspenders on top of the unit's network-online ordering.
echo "  Waiting for network..."
connected=0
for _ in $(seq 1 30); do
  if ping -c1 -W2 github.com >/dev/null 2>&1; then connected=1; break; fi
  sleep 2
done
if [ "$connected" -ne 1 ]; then
  echo "  !! No network after ~60s. Connect (e.g. iwctl) and reboot to retry." >&2
  exit 1
fi

# Always undo our temporary changes on exit, however we leave.
cleanup() {
  rm -f "$SUDO_DROPIN"
  if [ "${made_swap:-0}" -eq 1 ]; then
    swapoff "$SWAPFILE" 2>/dev/null || true
    rm -f "$SWAPFILE"
  fi
}
trap cleanup EXIT

# Open the temporary passwordless-sudo window for the install run only.
printf '%s ALL=(ALL) NOPASSWD: ALL\n' "$USERNAME" > "$SUDO_DROPIN"
chmod 440 "$SUDO_DROPIN"

# Rust AUR packages (e.g. swayosd-git) build with LTO and spawn one rustc per
# core, each needing ~1.5-2 GiB. On small machines that exhausts RAM and rustc
# gets OOM-killed. If there's little RAM and no real swap, add a temporary
# swapfile for the build; cleanup() removes it when we're done.
mem_kb=$(awk '/^MemTotal:/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
swap_kb=$(awk '/^SwapTotal:/{print $2}' /proc/meminfo 2>/dev/null || echo 0)
if [ "${swap_kb:-0}" -lt 1048576 ] && [ "${mem_kb:-0}" -lt 8388608 ]; then
  echo "  Low memory and no swap; adding a temporary 8 GiB swapfile for the build..."
  if fallocate -l 8G "$SWAPFILE" 2>/dev/null || \
     dd if=/dev/zero of="$SWAPFILE" bs=1M count=8192 status=none 2>/dev/null; then
    chmod 600 "$SWAPFILE"
    if mkswap "$SWAPFILE" >/dev/null 2>&1 && swapon "$SWAPFILE" 2>/dev/null; then
      made_swap=1
    else
      rm -f "$SWAPFILE"
      echo "  !! Could not enable swap; continuing (build may fail on low RAM)." >&2
    fi
  else
    echo "  !! Not enough disk for a swapfile; continuing without it." >&2
  fi
fi

# Run the SharkOS desktop installer as the user (login shell sets HOME/USER).
# Download to a file and verify it FIRST, rather than `curl | bash`: a 404 or
# DNS failure makes `curl -f` emit nothing and exit non-zero, but piping that
# to bash would run an empty script that exits 0 — falsely marking first-boot
# "done" and leaving an empty system with no retry. Downloading first makes a
# fetch failure abort here (no marker → retried next boot).
SCRIPT="$(runuser -l "$USERNAME" -c 'mktemp /tmp/sharkos-install.XXXXXX')"

install_ok=0
if ! runuser -l "$USERNAME" -c "curl -fsSL '$SETUP_URL' -o '$SCRIPT'"; then
  echo "  !! Could not download the SharkOS installer from:" >&2
  echo "     $SETUP_URL" >&2
  echo "     (A private repo returns 404 here; check network/DNS and repo access.)" >&2
elif ! runuser -l "$USERNAME" -c "test -s '$SCRIPT'"; then
  echo "  !! Downloaded installer is empty — aborting." >&2
elif runuser -l "$USERNAME" -c "script -qefc 'bash $SCRIPT' /dev/null"; then
  # Run under `script` so the install gets a pseudo-tty. yay/makepkg open
  # /dev/tty for their prompts; without a controlling terminal (this is a
  # oneshot service) they fail with "open /dev/tty: no such device". The pty
  # also means --noconfirm prompts auto-proceed instead of erroring.
  install_ok=1
fi
runuser -l "$USERNAME" -c "rm -f '$SCRIPT'" 2>/dev/null || true

if [ "$install_ok" -eq 1 ]; then
  touch "$DONE_MARKER"
  cleanup; trap - EXIT
  systemctl disable sharkos-firstboot.service >/dev/null 2>&1 || true
  echo
  echo "  SharkOS desktop installed. Rebooting in 10s (Ctrl-C to cancel)..."
  sleep 10 || true
  systemctl reboot
else
  echo
  echo "  !! SharkOS desktop install did not complete; will retry on next boot." >&2
  echo "     (Network/DNS, private-repo access, or AUR build failures are the usual causes.)" >&2
  exit 1
fi
