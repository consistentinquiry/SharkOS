{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "exclusive": true,

  "modules-left":   ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right":  ["pulseaudio", "network", "battery", "custom/clipboard", "custom/menu"],

  "hyprland/workspaces": {
    
"format": "{name}",
    "on-click": "activate",
    "sort-by-number": true
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "pulseaudio": {
    "format": "َ°•¾  {volume}%",
    "format-muted": "َ°–پ",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "scroll-step": 5
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°¤­",
    "tooltip-format-wifi": "{essid}  {signalStrength}%  {ipaddr}",
    "on-click": "rfkill unblock wifi; ghostty --class=com.sharkos.impala -e impala"
  },

  "battery": {
    "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "{icon}  {capacity}%  َ±گ‹",
    "format-plugged": "َ°ڑ¥  {capacity}%",
    "format-full": "َ°پ¹  {capacity}%",
