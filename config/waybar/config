  },

  "custom/clipboard": {
    "format": "َ°…Œ",
    "tooltip": false,
    "on-click": "sh -c 'cliphist list | walker --dmenu | cliphist decode | wl-copy'"
  },

  "custom/menu": {
    "format": "َ°چœ",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/hub-menu.sh"
  }
}
