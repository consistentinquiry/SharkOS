{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "exclusive": true,

  "modules-left":   ["hyprland/workspaces", "custom/media"],
  "modules-center": ["clock", "custom/update"],
  "modules-right":  ["pulseaudio", "network", "battery", "custom/notification", "custom/clipboard", "custom/menu"],

  "hyprland/workspaces": {
    
"format": "{name}",
    "on-click": "activate",
    "sort-by-number": true
  },

  "custom/media": {
    "format": "{}",
    "max-length": 45,
    "interval": 3,
    "exec": "~/.config/hypr/scripts/media-status.sh",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": false
  },

  "custom/update": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/sharkos-update-check.sh",
    "interval": 1800,
    "signal": 9,
    "on-click": "~/.config/hypr/scripts/sharkos-update-launch.sh"
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "pulseaudio": {
    "format": "σΑïΨ  {volume}%",
    "format-muted": "σΑ•¹",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "scroll-step": 5
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
    "format-ethernet": "σΑàÄ",
    "format-disconnected": "σΑΛ≠",
    "tooltip-format-wifi": "{essid}  {signalStrength}%  {ipaddr}",
    "on-click": "rfkill unblock wifi; ghostty --class=com.sharkos.impala -e impala"
  },

  "battery": {
    "states": {
        "good": 95,
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "{icon}  {capacity}%  σ±ê΄",
    "format-plugged": "σΑöΞ  {capacity}%",
    "format-full": "σΑ¹Ι  {capacity}%",
    "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
    "tooltip-format": "{timeTo}, {power:.1f}W"
  },

  "custom/notification": {
    "format": "{icon}<sup>{}</sup>",
    "format-icons": {
      "notification": "σΑ²ö",
      "none": "σΑ²€",
      "dnd-notification": "σΑ²ö",
      "dnd-none": "σΑ²¦",
      "inhibited-notification": "σΑ²ö",
      "inhibited-none": "σΑ²€",
      "dnd-inhibited-notification": "σΑ²ö",
      "dnd-inhibited-none": "σΑ²¦"
    },
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/swaync-status.sh",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "tooltip": true,
    "escape": true
  },

  "custom/clipboard": {
    "format": "σΑÖ¨",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/clipboard-menu.sh"
  },

  "custom/menu": {
    "format": "σΑç€",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/hub-menu.sh"
  }
}
