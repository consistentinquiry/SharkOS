{
  "layer": "top",
  "position": "top",
  "height": 38,
  "spacing": 0,
  "exclusive": true,

  "modules-left":   ["hyprland/workspaces", "custom/media"],
  "modules-center": ["clock", "custom/update"],
  "modules-right":  ["custom/menu", "pulseaudio", "network", "bluetooth", "battery", "custom/clipboard", "custom/notification"],

  "hyprland/workspaces": {
    
"format": "{name}",
    "on-click": "activate",
    "sort-by-number": true
  },

  "custom/media": {
    "format": "{}",
    "max-length": 45,
    "interval": 3,
    "exec": "~/.config/hypr/scripts/media-status.sh",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip": false
  },

  "custom/update": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/sharkos-update-check.sh",
    "interval": 1800,
    "signal": 9,
    "on-click": "~/.config/hypr/scripts/sharkos-update-launch.sh"
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>"
  },

  "pulseaudio": {
    "format": "󰕾  {volume}%",
    "format-muted": "󰖁",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "scroll-step": 5
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
    "format-ethernet": "󰈀",
    "format-disconnected": "󰤭",
    "tooltip-format-wifi": "{essid}  {signalStrength}%  {ipaddr}",
    "on-click": "rfkill unblock wifi; ghostty --class=com.sharkos.impala -e impala"
  },

  "bluetooth": {
    "format": "󰂯",
    "format-off": "󰂲",
    "format-disabled": "󰂲",
    "format-connected": "󰂱",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "rfkill unblock bluetooth; ghostty --class=com.sharkos.bluetui -e bluetui"
  },

  "battery": {
    "states": {
        "warning": 40,
        "critical": 10
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "{icon}  {capacity}%  󱐋",
    "format-plugged": "󰚥  {capacity}%",
    "format-full": "󰁹  {capacity}%",
    "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip-format": "{timeTo}, {power:.1f}W",
    "on-click": "ghostty --class=com.sharkos.jolt -e jolt"
  },

  "custom/notification": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/hypr/scripts/swaync-status.sh",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "tooltip": true,
    "escape": false
  },

  "custom/clipboard": {
    "format": "󰅌",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/clipboard-menu.sh"
  },

  "custom/menu": {
    "format": "󰍜",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/hub-menu.sh"
  }
}
