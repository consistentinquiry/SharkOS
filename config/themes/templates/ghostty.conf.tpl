background = {{COLOR_BG}}
foreground = {{COLOR_FG}}
# Frosted glass: a translucent background lets Hyprland's blur (the same UI Glass
# blur used by walker/swaync) frost the desktop behind the terminal. Forced to 1
# (opaque) when UI Glass is off — see TERM_OPACITY in apply-theme.sh.
background-opacity = {{TERM_OPACITY}}
font-family = JetBrainsMono Nerd Font
font-size = 13

window-padding-x = 12
window-padding-y = 8

# Terminal palette
palette = 0={{COLOR_0}}
palette = 1={{COLOR_1}}
palette = 2={{COLOR_2}}
palette = 3={{COLOR_3}}
palette = 4={{COLOR_4}}
palette = 5={{COLOR_5}}
palette = 6={{COLOR_6}}
palette = 7={{COLOR_7}}
palette = 8={{COLOR_8}}
palette = 9={{COLOR_9}}
palette = 10={{COLOR_10}}
palette = 11={{COLOR_11}}
palette = 12={{COLOR_12}}
palette = 13={{COLOR_13}}
palette = 14={{COLOR_14}}
palette = 15={{COLOR_15}}

cursor-color = {{COLOR_CURSOR}}
selection-background = {{COLOR_SELECTION_BG}}
selection-foreground = {{COLOR_SELECTION_FG}}
