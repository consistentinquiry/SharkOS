general {
    col.active_border = rgba({{BORDER_ACTIVE}})
    col.inactive_border = rgba({{BORDER_INACTIVE}})
}

# Window corner rounding follows the theme: noir is rounded, Omarchy themes are
# squared (0). Sourced by hyprland.conf, which no longer hard-codes rounding.
decoration {
    rounding = {{WINDOW_ROUNDING}}
}
