# Editor / OS cruft
*.swp
*.swo
*~
.DS_Store
*.log

# Install-time backups
*.bak

# Generated Omarchy-derived themes — rebuilt by config/themes/generate-omarchy-themes.sh
# (palettes + ~27MB of wallpapers, all reproducible from the upstream omarchy repo)
config/themes/omarchy-*/

# Runtime state — which theme is currently active
config/themes/.current

# ISO build output (built by ./build-iso.sh)
dist/

# Rendered theme outputs — regenerated by apply-theme.sh on install / theme switch.
# Tracking them causes churn on every switch and leaks machine-specific paths.
config/waybar/style.css
config/ghostty/config
config/swaync/style.css
config/swayosd/style.css
config/jolt/themes/sharkos.toml
config/walker/themes/noir/style.css
config/hypr/colors.conf
config/hypr/hyprlock.conf
config/hypr/hyprpaper.conf
